{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/config-schema.json",
  "name": "blytz-ventures-web",
  "main": "src/_worker.js",
  "compatibility_date": "2026-06-16",
  "assets": {
    "directory": "dist"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "blytz_ventures_contact",
      "database_name": "blytz-ventures-contact",
      "database_id": "ebee715f-81a3-4e87-992c-a7f8cf12e09a"
    }
  ]
}
