---
const steps = [
  { number: "01", title: "Identify", desc: "Spot high-impact opportunities in underserved markets" },
  { number: "02", title: "Build", desc: "Assemble lean teams and ship MVPs rapidly" },
  { number: "03", title: "Scale", desc: "Deploy capital and expertise to accelerate growth" }
];
---

<section class="section-padding bg-black relative overflow-hidden">
  <!-- Subtle glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-amber-500/5 rounded-full blur-3xl pointer-events-none"></div>
  
  <div class="container-max relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16">
      <div class="lg:col-span-5">
        <div class="scroll-reveal inline-flex items-center gap-3 bg-white/5 border border-white/10 px-4 py-2 rounded-full mb-6">
          <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
          <span class="text-xs font-semibold uppercase tracking-widest text-amber-400">Our Approach</span>
        </div>
        <h2 class="scroll-reveal text-section text-white">
          HOW WE<br />WORK
        </h2>
      </div>
      
      <div class="lg:col-span-7 flex items-end">
        <p class="scroll-reveal text-subhero text-white/50 max-w-2xl">
          We build, fund, and scale companies through a proven startup studio model. Our approach combines speed, capital, and deep operational expertise.
        </p>
      </div>
    </div>
    
    <!-- Bento steps grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-14">
      {steps.map((step, i) => (
        <div class="scroll-reveal-delay bento-card p-8 relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-br from-amber-500/10 to-yellow-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative z-10">
            <span class="text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-yellow-300 opacity-20 absolute -top-3 -right-3">
              {step.number}
            </span>
            
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-amber-500 to-yellow-500 flex items-center justify-center mb-6">
              <span class="text-xl font-extrabold text-black">{step.number}</span>
            </div>
            
            <h3 class="text-2xl font-extrabold text-white mb-3 tracking-tight">{step.title}</h3>
            <p class="text-base text-white/50 leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Bottom stats -->
    <div class="scroll-reveal bento-card p-8">
      <div class="flex flex-wrap gap-6 justify-center">
        <div class="flex items-center gap-3">
          <div class="w-2.5 h-2.5 rounded-full bg-amber-500"></div>
          <span class="text-base font-semibold text-white">Founded 2024</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
          <span class="text-base font-semibold text-white">SEA Focus</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-2.5 h-2.5 rounded-full bg-orange-500"></div>
          <span class="text-base font-semibold text-white">4 Companies</span>
        </div>
      </div>
    </div>
  </div>
</section>
