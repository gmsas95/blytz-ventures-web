        <nav class="flex flex-col gap-4">
          <a href="/coming-soon?v=cloud" class="text-lg text-white/70 hover:text-white transition-colors">Blytz Cloud</a>
          <a href="/coming-soon?v=marketplace" class="text-lg text-white/70 hover:text-white transition-colors">Blytz Marketplace</a>
          <a href="/coming-soon?v=work" class="text-lg text-white/70 hover:text-white transition-colors">Blytz Work</a>
