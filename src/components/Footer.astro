---

<footer class="relative bg-black text-white py-20 overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 bg-gradient-to-t from-cyan-500/5 to-transparent"></div>
  
  <div class="relative z-10 container mx-auto px-4 text-center">
    <h2 class="text-4xl md:text-5xl font-bold mb-4">Have a project in mind?</h2>
    <p class="text-lg text-neutral-300 mb-8">Let's create something amazing together.</p>
    <a href="/contact" class="inline-block bg-white text-black font-bold py-4 px-8 rounded-full text-lg hover:scale-105 transition-transform">
      Get in Touch
    </a>
    
    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center">
      <p class="text-neutral-400">
        &copy; {new Date().getFullYear()} Blytz Ventures. All rights reserved.
      </p>
      <div class="flex gap-6 mt-4 md:mt-0">
        <a href="https://linkedin.com/company/blytz-ventures" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-white transition-colors">
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</footer>
