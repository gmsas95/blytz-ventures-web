---
---

<section class="py-24 md:py-32 bg-[#0a0a0a]">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center mb-20">
      <span class="inline-block mb-4 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-neutral-400 text-sm font-medium">
        Who We Are
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        About <span class="gradient-text">Blytz Ventures</span>
      </h2>
      <p class="text-lg md:text-xl text-neutral-400 max-w-4xl mx-auto leading-relaxed">
        We exist to drive innovation, market speed, and build impactful companies. Our startup studio model creates, funds, and scales subsidiaries that shape the future.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="glass-card p-8 rounded-2xl text-center hover-lift cursor-pointer">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-cyan-500 to-blue-500 rounded-xl mb-6 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
        </div>
        <h3 class="text-xl font-bold mb-3">Speed & Agility</h3>
        <p class="text-neutral-400 leading-relaxed">Fast execution cycles that bring ideas to market quickly</p>
      </div>

      <div class="glass-card p-8 rounded-2xl text-center hover-lift cursor-pointer">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl mb-6 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        </div>
        <h3 class="text-xl font-bold mb-3">Cross-Industry Innovation</h3>
        <p class="text-neutral-400 leading-relaxed">Where technology meets diverse sectors for breakthrough solutions</p>
      </div>

      <div class="glass-card p-8 rounded-2xl text-center hover-lift cursor-pointer">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-emerald-500 to-cyan-500 rounded-xl mb-6 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M12 2v20"/><path d="m17 5-5 5-5-5"/><path d="m17 19-5-5-5 5"/></svg>
        </div>
        <h3 class="text-xl font-bold mb-3">Scalable Impact</h3>
        <p class="text-neutral-400 leading-relaxed">Targeting high-growth, high-impact markets globally</p>
      </div>
    </div>

    <div class="mt-16 flex flex-wrap items-center justify-center gap-8 text-sm text-neutral-500">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 bg-cyan-500 rounded-full animate-pulse"></span>
        <span>Founded 2024</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
        <span>4 Active Projects</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
        <span>Expanding Pipeline</span>
      </div>
    </div>
  </div>
</section>
