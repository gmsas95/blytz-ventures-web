---
const stats = [
  { number: "04", label: "Companies", sublabel: "Active Ventures" },
  { number: "2024", label: "Founded", sublabel: "Year Established" },
  { number: "SEA", label: "Focus", sublabel: "Region" }
];
---

<section class="section-padding bg-black relative overflow-hidden">
  <!-- Subtle glow -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-amber-500/5 rounded-full blur-3xl pointer-events-none"></div>
  
  <div class="container-max relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-24">
      <div class="lg:col-span-5">
        <div class="scroll-reveal inline-flex items-center gap-3 bg-white/5 border border-white/10 px-4 py-2 rounded-full mb-8">
          <span class="text-xs font-semibold uppercase tracking-widest text-amber-400">About Us</span>
        </div>
        <h2 class="scroll-reveal text-section text-white">
          WHAT WE<br />BUILD
        </h2>
      </div>
      
      <div class="lg:col-span-7 flex items-end">
        <p class="scroll-reveal text-subhero text-white/50 max-w-2xl">
           We're a startup studio building and scaling ventures across Southeast Asia. From AI assistants to talent platforms, we're creating the future one venture at a time — all currently under development.
        </p>
      </div>
    </div>
    
    <!-- Bento stats grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
      {stats.map((stat, index) => (
        <div class="scroll-reveal-delay bento-card p-10 relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-br from-amber-500/10 to-yellow-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <span class="text-7xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-yellow-300 opacity-20 absolute -top-4 -right-4">
              0{index + 1}
            </span>
            <span class="text-6xl md:text-7xl font-extrabold text-white tracking-tight">{stat.number}</span>
            <p class="text-xl font-semibold text-white/80 mt-2">{stat.label}</p>
            <p class="text-sm text-white/40 mt-1">{stat.sublabel}</p>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Tags -->
    <div class="scroll-reveal flex flex-wrap gap-4 justify-center">
      <div class="flex items-center gap-3 px-6 py-3 bg-white/5 border border-white/10 rounded-full">
        <div class="w-2.5 h-2.5 rounded-full bg-amber-500"></div>
        <span class="text-sm font-medium text-white/70">Startup Studio Model</span>
      </div>
      <div class="flex items-center gap-3 px-6 py-3 bg-white/5 border border-white/10 rounded-full">
        <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
        <span class="text-sm font-medium text-white/70">Cross-Industry Innovation</span>
      </div>
      <div class="flex items-center gap-3 px-6 py-3 bg-white/5 border border-white/10 rounded-full">
        <div class="w-2.5 h-2.5 rounded-full bg-orange-500"></div>
        <span class="text-sm font-medium text-white/70">Scalable Impact</span>
      </div>
    </div>
  </div>
</section>
