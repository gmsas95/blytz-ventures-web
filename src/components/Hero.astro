---
---

<section class="relative bg-white overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 bg-sky-100 rounded-full blur-3xl opacity-50 animate-pulse-slow"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-indigo-100 rounded-full blur-3xl opacity-50 animate-pulse-slow" style="animation-delay: 2s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-radial from-sky-50 to-transparent opacity-40"></div>
  </div>

  <div class="container-max relative z-10 py-32 md:py-48 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-sky-50 border border-sky-100 text-sky-700 text-sm font-medium mb-8 animate-in">
      <span class="w-2 h-2 rounded-full bg-sky-500 animate-pulse"></span>
      Startup Studio from Southeast Asia
    </div>
    
    <h1 class="text-5xl md:text-8xl font-bold text-slate-900 mb-8 leading-[1.1] tracking-tight animate-in">
      Building the next generation of<br />
      <span class="gradient-text-hero">Southeast Asian tech companies</span>
    </h1>
    
    <p class="text-xl md:text-2xl text-slate-600 mb-12 max-w-3xl mx-auto leading-relaxed animate-in-up">
      Blytz Ventures is a startup studio that builds, funds, and scales innovative companies. 
      From AI assistants to talent platforms, we're creating the future.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-in-up">
      <a href="#ventures" class="btn-primary group text-lg">
        See our companies
        <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a href="/contact" class="btn-secondary text-lg">
        Get in touch
      </a>
    </div>

    <!-- Stats -->
    <div class="mt-24 grid grid-cols-3 gap-8 md:gap-16 max-w-3xl mx-auto animate-in-up">
      <div class="text-center">
        <div class="text-4xl md:text-5xl font-bold text-slate-900">4</div>
        <div class="text-slate-500 mt-1">Companies</div>
      </div>
      <div class="text-center">
        <div class="text-4xl md:text-5xl font-bold text-slate-900">2024</div>
        <div class="text-slate-500 mt-1">Founded</div>
      </div>
      <div class="text-center">
        <div class="text-4xl md:text-5xl font-bold text-slate-900">SEA</div>
        <div class="text-slate-500 mt-1">Focus</div>
      </div>
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-slate-50 to-transparent"></div>
</section>
