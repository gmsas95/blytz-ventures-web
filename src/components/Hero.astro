---
---

<section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden bg-[#0a0a0a]">
  <!-- Animated background -->
  <div class="absolute inset-0 overflow-hidden">
    <!-- Gradient orbs -->
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;"></div>
  </div>
  
  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto py-32">
    <div class="fade-in mb-6">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm font-medium">
        <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
        Building the Future
      </span>
    </div>
    
    <h1 class="font-bold text-5xl md:text-6xl lg:text-7xl mb-8 leading-tight opacity-0 fade-in-up stagger-1">
      Creating <span class="gradient-text">Impact</span>,<br />
      One Venture at a Time
    </h1>
    
    <p class="text-lg md:text-xl text-neutral-400 mb-12 max-w-2xl mx-auto leading-relaxed opacity-0 fade-in-up stagger-2">
      Blytz Ventures builds and scales innovative platforms across Southeast Asia. From AI assistants to talent matching, we're building what's next.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center opacity-0 fade-in-up stagger-3">
      <a href="#ventures" class="group inline-flex items-center justify-center gap-2 bg-white text-black font-semibold py-4 px-8 rounded-lg transition-all duration-300 hover:bg-cyan-50 hover:shadow-lg hover:shadow-cyan-500/20 hover:-translate-y-0.5 cursor-pointer">
        Our Ventures
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a href="/contact" class="group inline-flex items-center justify-center gap-2 border border-neutral-600 text-white font-medium py-4 px-8 rounded-lg transition-all duration-300 hover:bg-white/5 hover:border-white/40 hover:-translate-y-0.5 cursor-pointer">
        Get in Touch
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 fade-in stagger-4">
    <div class="flex flex-col items-center gap-2 text-neutral-500 text-sm">
      <span>Scroll</span>
      <div class="w-6 h-10 rounded-full border-2 border-neutral-700 flex justify-center pt-2">
        <div class="w-1.5 h-1.5 rounded-full bg-neutral-500 animate-bounce"></div>
      </div>
    </div>
  </div>
</section>
