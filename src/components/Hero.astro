---
---

<section class="relative w-full min-h-screen flex items-center justify-center bg-[#0a0a0a]">
  <!-- Subtle grid -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 60px 60px;"></div>
  
  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto py-32">
    <h1 class="font-bold text-4xl md:text-5xl lg:text-6xl mb-6 leading-tight">
      Building the Future,<br />
      <span class="text-cyan-400">One Venture at a Time</span>
    </h1>
    
    <p class="text-base md:text-lg text-neutral-400 mb-10 max-w-2xl mx-auto">
      Blytz Ventures creates and scales innovative platforms across Southeast Asia. From AI assistants to talent matching, we're building what's next.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#ventures" class="inline-flex items-center justify-center gap-2 bg-white text-black font-medium py-3 px-6 rounded-lg transition-colors hover:bg-neutral-200">
        Our Ventures
      </a>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 border border-neutral-700 text-white font-medium py-3 px-6 rounded-lg transition-colors hover:bg-neutral-800">
        Get in Touch
      </a>
    </div>
  </div>
</section>
