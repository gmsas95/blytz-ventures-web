---
---

<section id="ventures" class="py-24 md:py-32 bg-[#111]">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-6xl font-bold mb-8 opacity-0 animate-slide-up">Our <span class="gradient-text">Ventures</span></h2>
      <p class="text-lg md:text-xl text-neutral-300 max-w-3xl mx-auto leading-relaxed opacity-0 animate-slide-up stagger-1">
        Discover our portfolio of innovative subsidiaries driving change across technology, entertainment, and digital services.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Blytz Live -->
      <div class="group h-full bg-[#1a1a1a] rounded-2xl overflow-hidden border border-neutral-800 hover:border-cyan-500/50 transition-all duration-300 opacity-0 animate-slide-up stagger-2">
        <div class="relative h-48 bg-gradient-to-br from-cyan-500/20 to-blue-500/20 flex items-center justify-center">
          <div class="absolute top-6 left-6">
            <span class="inline-flex items-center gap-2 bg-gradient-to-r from-cyan-500 to-blue-500 text-black px-4 py-2 rounded-full text-sm font-semibold">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="10" height="18" x="7" y="3" rx="2"/><path d="M12 18h.01"/></svg>
              Tech Platform
            </span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-400/50 group-hover:text-cyan-400 transition-colors"><polygon points="6 3 20 12 6 21 6 3"/></svg>
        </div>
        <div class="p-8">
          <h3 class="text-3xl font-bold mb-3">Blytz Live</h3>
          <p class="text-lg font-semibold mb-4 gradient-text">Fastest Live Auction Experience in Southeast Asia</p>
          <p class="text-neutral-400 mb-8 leading-relaxed">Revolutionary live commerce platform combining speed, urgency, and gamified auction experiences for the Southeast Asian market.</p>
          <a href="http://live.blytzventures.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-3 bg-gradient-to-r from-cyan-500 to-blue-500 text-black font-semibold py-4 px-6 rounded-full transition-all duration-300 w-full hover:scale-105">
            Explore Blytz Live
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
          </a>
        </div>
      </div>

      <!-- Blytz Digital -->
      <div class="group h-full bg-[#1a1a1a] rounded-2xl overflow-hidden border border-neutral-800 hover:border-green-500/50 transition-all duration-300 opacity-0 animate-slide-up stagger-3">
        <div class="relative h-48 bg-gradient-to-br from-green-500/20 to-emerald-500/20 flex items-center justify-center">
          <div class="absolute top-6 left-6">
            <span class="inline-flex items-center gap-2 bg-gradient-to-r from-green-500 to-emerald-500 text-black px-4 py-2 rounded-full text-sm font-semibold">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
              Digital Services
            </span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-green-400/50 group-hover:text-green-400 transition-colors"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        </div>
        <div class="p-8">
          <h3 class="text-3xl font-bold mb-3">Blytz Digital</h3>
          <p class="text-lg font-semibold mb-4 gradient-text-green">Full-Stack Digital Solutions & Web Development</p>
          <p class="text-neutral-400 mb-8 leading-relaxed">End-to-end digital transformation services, from web development to brand strategy, empowering businesses to thrive online.</p>
          <a href="#" class="inline-flex items-center justify-center gap-3 bg-gradient-to-r from-green-500 to-emerald-500 text-black font-semibold py-4 px-6 rounded-full transition-all duration-300 w-full hover:scale-105">
            Explore Blytz Digital
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
          </a>
        </div>
      </div>

      <!-- Blytz Media -->
      <div class="group h-full bg-[#1a1a1a] rounded-2xl overflow-hidden border border-neutral-800 hover:border-purple-500/50 transition-all duration-300 opacity-0 animate-slide-up stagger-4">
        <div class="relative h-48 bg-gradient-to-br from-purple-500/20 to-pink-500/20 flex items-center justify-center">
          <div class="absolute top-6 left-6">
            <span class="inline-flex items-center gap-2 bg-gradient-to-r from-purple-500 to-pink-500 text-black px-4 py-2 rounded-full text-sm font-semibold">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
              Media & Entertainment
            </span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400/50 group-hover:text-purple-400 transition-colors"><path d="M4 19V5"/><path d="M20 19V9"/><path d="M4 19h16"/><circle cx="9" cy="12" r="2"/><circle cx="15" cy="14" r="2"/></svg>
        </div>
        <div class="p-8">
          <h3 class="text-3xl font-bold mb-3">Blytz Media</h3>
          <p class="text-lg font-semibold mb-4 bg-gradient-to-r from-purple-400 to-pink-500 bg-clip-text text-transparent">Content Creation & Digital Entertainment</p>
          <p class="text-neutral-400 mb-8 leading-relaxed">Producing engaging digital content and entertainment experiences that connect with audiences across Southeast Asia.</p>
          <a href="#" class="inline-flex items-center justify-center gap-3 bg-gradient-to-r from-purple-500 to-pink-500 text-black font-semibold py-4 px-6 rounded-full transition-all duration-300 w-full hover:scale-105">
            Explore Blytz Media
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
          </a>
        </div>
      </div>

      <!-- Blytz Labs -->
      <div class="group h-full bg-[#1a1a1a] rounded-2xl overflow-hidden border border-neutral-800 hover:border-orange-500/50 transition-all duration-300 opacity-0 animate-slide-up stagger-5">
        <div class="relative h-48 bg-gradient-to-br from-orange-500/20 to-amber-500/20 flex items-center justify-center">
          <div class="absolute top-6 left-6">
            <span class="inline-flex items-center gap-2 bg-gradient-to-r from-orange-500 to-amber-500 text-black px-4 py-2 rounded-full text-sm font-semibold">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v7.5L4 18h16l-4-8.5V2"/><path d="M11 10h2"/><path d="M11 14h2"/></svg>
              R&D / Innovation
            </span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-orange-400/50 group-hover:text-orange-400 transition-colors"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 12 2.5 7.5"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <div class="p-8">
          <h3 class="text-3xl font-bold mb-3">Blytz Labs</h3>
          <p class="text-lg font-semibold mb-4 bg-gradient-to-r from-orange-400 to-amber-500 bg-clip-text text-transparent">Experimental Tech & Emerging Solutions</p>
          <p class="text-neutral-400 mb-8 leading-relaxed">Our innovation sandbox — exploring AI, blockchain, and emerging technologies to identify the next big opportunity.</p>
          <a href="#" class="inline-flex items-center justify-center gap-3 bg-gradient-to-r from-orange-500 to-amber-500 text-black font-semibold py-4 px-6 rounded-full transition-all duration-300 w-full hover:scale-105">
            Explore Blytz Labs
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
