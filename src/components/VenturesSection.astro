---
---

<section id="ventures" class="py-24 md:py-32 bg-[#0a0a0a]">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-6xl font-bold mb-8">Our <span class="gradient-text">Ventures</span></h2>
      <p class="text-lg md:text-xl text-neutral-400 max-w-3xl mx-auto leading-relaxed">
        Our portfolio of platforms driving innovation across Southeast Asia.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Blytz Cloud -->
      <a href="https://blytz.cloud" target="_blank" rel="noopener noreferrer" class="group block h-full">
        <div class="bg-[#0f0f0f] rounded-xl overflow-hidden border border-neutral-800 hover:border-cyan-500/50 transition-all duration-300 h-full p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-cyan-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold">Blytz Cloud</h3>
              <span class="text-xs text-cyan-400">AI Assistant Platform</span>
            </div>
          </div>
          <p class="text-sm text-neutral-400 mb-4">Platform for deploying personalized OpenClaw AI assistants via Telegram.</p>
          <div class="flex items-center gap-2 text-xs text-neutral-500">
            <span class="px-2 py-1 bg-neutral-800 rounded">Go</span>
            <span class="px-2 py-1 bg-neutral-800 rounded">Docker</span>
            <span class="px-2 py-1 bg-neutral-800 rounded">Stripe</span>
          </div>
        </div>
      </a>

      <!-- Blytz Marketplace -->
      <a href="https://blytz.market" target="_blank" rel="noopener noreferrer" class="group block h-full">
        <div class="bg-[#0f0f0f] rounded-xl overflow-hidden border border-neutral-800 hover:border-yellow-500/50 transition-all duration-300 h-full p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-yellow-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold">Blytz Marketplace</h3>
              <span class="text-xs text-yellow-400">E-Commerce / Live Auction</span>
            </div>
          </div>
          <p class="text-sm text-neutral-400 mb-4">E-commerce with live auctions, real-time bidding, Stripe Connect.</p>
          <div class="flex items-center gap-2 text-xs text-neutral-500">
            <span class="px-2 py-1 bg-neutral-800 rounded">Go</span>
            <span class="px-2 py-1 bg-neutral-800 rounded">Next.js</span>
            <span class="px-2 py-1 bg-neutral-800 rounded">Stripe</span>
          </div>
        </div>
      </a>

      <!-- Blytz Work -->
      <a href="https://blytz.work" target="_blank" rel="noopener noreferrer" class="group block h-full">
        <div class="bg-[#0f0f0f] rounded-xl overflow-hidden border border-neutral-800 hover:border-purple-500/50 transition-all duration-300 h-full p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-purple-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold">Blytz Work</h3>
              <span class="text-xs text-purple-400">Talent Matching</span>
            </div>
          </div>
          <p class="text-sm text-neutral-400 mb-4">Fastest job matching platform. From job posted to hired in under 1 hour.</p>
          <div class="flex items-center gap-2 text-xs text-neutral-500">
            <span class="px-2 py-1 bg-neutral-800 rounded">Node.js</span>
            <span class="px-2 py-1 bg-neutral-800 rounded">Next.js</span>
            <span class="px-2 py-1 bg-neutral-800 rounded">Firebase</span>
          </div>
        </div>
      </a>

      <!-- Blytz Site -->
      <a href="https://blytz.site" target="_blank" rel="noopener noreferrer" class="group block h-full">
        <div class="bg-[#0f0f0f] rounded-xl overflow-hidden border border-neutral-800 hover:border-green-500/50 transition-all duration-300 h-full p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold">Blytz Site</h3>
              <span class="text-xs text-green-400">Website Builder</span>
            </div>
          </div>
          <p class="text-sm text-neutral-400 mb-4">Website builder and management platform with custom plugins.</p>
          <div class="flex items-center gap-2 text-xs text-neutral-500">
            <span class="px-2 py-1 bg-neutral-800 rounded">Go</span>
            <span class="px-2 py-1 bg-neutral-800 rounded">Next.js</span>
            <span class="px-2 py-1 bg-neutral-800 rounded">Caddy</span>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
