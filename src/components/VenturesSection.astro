---
const ventures = [
  { name: "Blytz Cloud", tagline: "AI Assistant Platform", url: "https://blytz.cloud" },
  { name: "Blytz Marketplace", tagline: "E-Commerce & Live Auctions", url: "https://blytz.market" },
  { name: "Blytz Work", tagline: "Fastest Job Matching", url: "https://blytz.work" },
  { name: "Blytz Site", tagline: "Website Builder Platform", url: "https://blytz.site" }
];
---

<section id="ventures" class="section-padding bg-slate-50">
  <div class="container-max">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4 text-center animate-in">
      Our Companies
    </h2>
    <p class="text-slate-600 mb-12 text-center animate-in-up">
      We're building across AI, e-commerce, talent, and web platforms.
    </p>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {ventures.map((venture, i) => (
        <a 
          href={venture.url} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group block p-6 bg-white rounded-xl border border-slate-200 hover:border-slate-400 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 cursor-pointer animate-in"
          style={`animation-delay: ${i * 100}ms`}
        >
          <h3 class="text-lg font-semibold text-slate-900 group-hover:text-sky-600 transition-colors">
            {venture.name}
          </h3>
          <p class="text-sm text-slate-500 mt-1">{venture.tagline}</p>
        </a>
      ))}
    </div>
  </div>
</section>
