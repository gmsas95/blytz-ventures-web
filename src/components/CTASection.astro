---
---

<section id="contact" class="py-24 md:py-32 bg-[#111]">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-6xl font-bold mb-8 opacity-0 animate-slide-up">Ready to Build the <span class="gradient-text">Future</span>?</h2>
      <p class="text-lg md:text-xl text-neutral-300 max-w-3xl mx-auto leading-relaxed opacity-0 animate-slide-up stagger-1">
        Whether you're an investor, talented individual, or have an innovative idea, we want to hear from you.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- For Investors -->
      <div class="bg-[#1a1a1a] p-8 rounded-2xl text-center border border-neutral-800 hover:border-neutral-700 transition-colors duration-300 h-full flex flex-col opacity-0 animate-slide-up stagger-2">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-cyan-500 to-blue-500 rounded-full mb-6 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
        </div>
        <h3 class="text-2xl font-bold mb-4">For Investors</h3>
        <p class="text-neutral-400 mb-8 leading-relaxed flex-grow">Discover partnership opportunities with Blytz Ventures</p>
        <a href="/contact" class="bg-gradient-to-r from-cyan-500 to-blue-500 text-black font-semibold py-4 px-6 rounded-full transition-all duration-300 w-full hover:scale-105 inline-block">
          Partner With Us
        </a>
      </div>

      <!-- For Talent -->
      <div class="bg-[#1a1a1a] p-8 rounded-2xl text-center border border-neutral-800 hover:border-neutral-700 transition-colors duration-300 h-full flex flex-col opacity-0 animate-slide-up stagger-3">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-green-500 to-emerald-500 rounded-full mb-6 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-2xl font-bold mb-4">For Talent</h3>
        <p class="text-neutral-400 mb-8 leading-relaxed flex-grow">Join our mission to build the future</p>
        <a href="/contact" class="bg-gradient-to-r from-green-500 to-emerald-500 text-black font-semibold py-4 px-6 rounded-full transition-all duration-300 w-full hover:scale-105 inline-block">
          Explore Careers
        </a>
      </div>

      <!-- For Collaborators -->
      <div class="bg-[#1a1a1a] p-8 rounded-2xl text-center border border-neutral-800 hover:border-neutral-700 transition-colors duration-300 h-full flex flex-col opacity-0 animate-slide-up stagger-4">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full mb-6 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </div>
        <h3 class="text-2xl font-bold mb-4">For Collaborators</h3>
        <p class="text-neutral-400 mb-8 leading-relaxed flex-grow">Have an innovative idea? Let's discuss it</p>
        <a href="/contact" class="bg-gradient-to-r from-purple-500 to-pink-500 text-black font-semibold py-4 px-6 rounded-full transition-all duration-300 w-full hover:scale-105 inline-block">
          Pitch Your Idea
        </a>
      </div>
    </div>
  </div>
</section>
