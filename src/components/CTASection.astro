---
---

<section id="contact" class="relative section-padding bg-zinc-950 text-white overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-rose-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-pink-500/10 rounded-full blur-3xl"></div>
  </div>

  <div class="container-max relative z-10 text-center">
    <h2 class="text-4xl md:text-6xl font-bold mb-6 animate-in">
      Let's build something together
    </h2>
    <p class="text-xl text-zinc-400 mb-10 max-w-2xl mx-auto animate-in-up">
      Have an idea? Want to collaborate? We'd love to hear from you.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-in-up">
      <a href="/contact" class="btn-primary text-lg">
        Get in touch
        <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
