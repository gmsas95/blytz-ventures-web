---
const ctaOptions = [
  {
    title: "For Investors",
    tagline: "Partner with Blytz",
    desc: "Discover partnership opportunities with Blytz Ventures",
    cta: "Partner With Us",
    href: "/contact",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
  },
  {
    title: "For Talent",
    tagline: "Join the Mission",
    desc: "Join our mission to build the future of Southeast Asian tech",
    cta: "Explore Careers",
    href: "/contact",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
  },
  {
    title: "For Founders",
    tagline: "Pitch Your Idea",
    desc: "Have an innovative idea? Let's build it together",
    cta: "Get In Touch",
    href: "/contact",
    icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
  }
];
---

<section id="contact" class="section-padding bg-black relative overflow-hidden">
  <!-- Background glows -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-amber-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-yellow-500/5 rounded-full blur-3xl"></div>
  </div>
  
  <div class="container-max relative z-10">
    <div class="scroll-reveal text-center mb-20">
      <div class="inline-flex items-center gap-3 bg-white/5 border border-white/10 px-4 py-2 rounded-full mb-8">
        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <span class="text-xs font-semibold uppercase tracking-widest text-white">Get In Touch</span>
      </div>
      
      <h2 class="text-section text-white mb-8">
        READY TO<br />BUILD?
      </h2>
      
      <p class="text-subhero text-white/50 max-w-2xl mx-auto">
        Whether you're an investor, talented individual, or have an innovative idea, we want to hear from you.
      </p>
    </div>
    
    <!-- Bento CTA cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {ctaOptions.map((option, i) => (
        <div class="scroll-reveal-delay bento-card p-10 relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-br from-amber-500/10 to-yellow-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative z-10">
            <div class="w-20 h-20 rounded-3xl bg-gradient-to-br from-amber-500 to-yellow-500 flex items-center justify-center mb-8">
              <svg class="w-9 h-9 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={option.icon} />
              </svg>
            </div>
            
            <span class="text-7xl font-extrabold text-transparent bg-clip-text bg-gradient-to-br from-amber-400 to-yellow-300 opacity-10 absolute -top-4 -right-4">
              0{i + 1}
            </span>
            
            <h3 class="text-3xl font-extrabold text-white mb-2 tracking-tight">{option.title}</h3>
            <p class="text-lg font-semibold text-amber-400 mb-4">{option.tagline}</p>
            <p class="text-white/50 mb-8 leading-relaxed">{option.desc}</p>
            
            <a href={option.href} class="btn-primary w-full justify-center group/btn">
              {option.cta}
              <svg class="w-5 h-5 ml-2 transition-transform group-hover/btn:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
