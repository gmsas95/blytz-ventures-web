---
---

<section id="contact" class="py-24 md:py-32 bg-[#0f0f0f]">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center mb-16">
      <span class="inline-block mb-4 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-neutral-400 text-sm font-medium">
        Let's Connect
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        Ready to Build the <span class="gradient-text">Future</span>?
      </h2>
      <p class="text-lg md:text-xl text-neutral-400 max-w-3xl mx-auto leading-relaxed">
        Whether you're an investor, talented individual, or have an innovative idea, we want to hear from you.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="glass-card p-8 rounded-2xl text-center hover-lift cursor-pointer">
        <div class="inline-flex items-center justify-center w-14 h-14 bg-gradient-to-br from-cyan-500 to-blue-500 rounded-xl mb-5 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
        </div>
        <h3 class="text-xl font-bold mb-3">For Investors</h3>
        <p class="text-neutral-400 mb-6 text-sm leading-relaxed">Discover partnership opportunities with Blytz Ventures</p>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-cyan-500 to-blue-500 text-black font-semibold py-3 px-6 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-cyan-500/20 hover:-translate-y-0.5 cursor-pointer w-full">
          Partner With Us
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="glass-card p-8 rounded-2xl text-center hover-lift cursor-pointer">
        <div class="inline-flex items-center justify-center w-14 h-14 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl mb-5 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-xl font-bold mb-3">For Talent</h3>
        <p class="text-neutral-400 mb-6 text-sm leading-relaxed">Join our mission to build the future</p>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-purple-500 to-pink-500 text-black font-semibold py-3 px-6 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/20 hover:-translate-y-0.5 cursor-pointer w-full">
          Explore Careers
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="glass-card p-8 rounded-2xl text-center hover-lift cursor-pointer">
        <div class="inline-flex items-center justify-center w-14 h-14 bg-gradient-to-br from-emerald-500 to-cyan-500 rounded-xl mb-5 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </div>
        <h3 class="text-xl font-bold mb-3">For Collaborators</h3>
        <p class="text-neutral-400 mb-6 text-sm leading-relaxed">Have an innovative idea? Let's discuss it</p>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-emerald-500 to-cyan-500 text-black font-semibold py-3 px-6 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-emerald-500/20 hover:-translate-y-0.5 cursor-pointer w-full">
          Pitch Your Idea
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
