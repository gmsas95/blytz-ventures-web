---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Blog - Blytz Ventures">
  <Header />
  <main class="pt-32 pb-20">
    <div class="container mx-auto px-6 max-w-4xl">
      <h1 class="text-4xl md:text-6xl font-bold mb-8 text-center">Blog</h1>
      <p class="text-lg text-neutral-400 text-center mb-16">Insights, updates, and thoughts from the Blytz Ventures team.</p>
      
      <div class="text-center py-20">
        <div class="inline-flex items-center gap-3 text-neutral-500">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          <span>Coming soon — stay tuned for updates</span>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
