---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const venture = Astro.url.searchParams.get("v");
const ventures = {
  cloud: { name: "Blytz Cloud", tagline: "AI Assistant Platform", icon: "🤖" },
  marketplace: { name: "Blytz Marketplace", tagline: "E-Commerce & Live Auctions", icon: "🛒" },
  work: { name: "Blytz Work", tagline: "Fastest Job Matching", icon: "💼" },
  site: { name: "Blytz Site", tagline: "Website Builder Platform", icon: "🌐" },
};
const current = ventures[venture] || null;
const title = current ? `${current.name} — Coming Soon` : "Coming Soon";
---

<Layout title={`${title} - Blytz Ventures`}>
  <Header />
  <main class="min-h-screen flex items-center justify-center bg-black pt-32">
    <div class="text-center px-6 max-w-lg">
      <div class="text-7xl mb-8">{current?.icon || "🚧"}</div>
      <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-4 tracking-tight">
        {current?.name || "Coming Soon"}
      </h1>
      <p class="text-2xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-yellow-300 mb-6">
        {current?.tagline || "Under Development"}
      </p>
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-300 text-sm font-semibold uppercase tracking-wider mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-amber-500"></span>
        </span>
        Under Development
      </div>
      <p class="text-lg text-white/50 mb-10 leading-relaxed">
        {current
          ? `${current.name} is currently being built. We're working hard to bring this venture to life.`
          : "This venture is currently under development. Stay tuned for updates."}
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/#ventures" class="btn-primary group">
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Ventures
        </a>
        <a href="/contact" class="btn-secondary group">
          Get in Touch
          <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
