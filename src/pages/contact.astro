---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact - Blytz Ventures">
  <Header />
  <main class="pt-32 pb-20">
    <div class="container mx-auto px-6 max-w-4xl">
      <h1 class="text-4xl md:text-6xl font-bold mb-8 text-center">Get in <span class="gradient-text">Touch</span></h1>
      <p class="text-lg text-neutral-400 text-center mb-16">Ready to build the future? Let's talk.</p>
      
      <div class="bg-[#1a1a1a] p-8 md:p-12 rounded-2xl border border-neutral-800 max-w-2xl mx-auto">
        <form class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium text-neutral-300 mb-2">Name</label>
            <input type="text" id="name" name="name" class="w-full bg-[#0a0a0a] border border-neutral-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition-colors" placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-neutral-300 mb-2">Email</label>
            <input type="email" id="email" name="email" class="w-full bg-[#0a0a0a] border border-neutral-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition-colors" placeholder="you@example.com" />
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-neutral-300 mb-2">Subject</label>
            <select id="subject" name="subject" class="w-full bg-[#0a0a0a] border border-neutral-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition-colors">
              <option value="">Select a topic</option>
              <option value="partnership">Partnership / Investment</option>
              <option value="careers">Careers</option>
              <option value="collaboration">Collaboration / Pitch</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-neutral-300 mb-2">Message</label>
            <textarea id="message" name="message" rows="5" class="w-full bg-[#0a0a0a] border border-neutral-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition-colors resize-none" placeholder="Tell us about your idea or inquiry..."></textarea>
          </div>
          <button type="submit" class="w-full bg-gradient-to-r from-cyan-500 to-blue-500 text-black font-semibold py-4 px-6 rounded-full hover:scale-105 transition-transform">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
